{
  "name": "jurename",
  "productName": "JuRename",
  "version": "1.0.9",
  "description": "My Electron application description",
  "main": "dist-electron/main.js",
  "private": true,
  "scripts": {
    "start": "node scripts/start.mjs",
    "website:build": "vite build --config vite.website.config.ts",
    "website:dev": "vite --config vite.website.config.ts",
    "version": "bun run website:build && git add docs",
    "release": "node scripts/release.mjs",
    "generate:icons": "node scripts/generate-icons.mjs",
    "build:main": "vite build --config vite.builder.main.config.ts",
    "build:preload": "vite build --config vite.builder.preload.config.ts",
    "build:renderer": "vite build --config vite.builder.renderer.config.ts",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "dist:mac": "npm run build && CSC_NAME=\"$MACOS_SIGNING_IDENTITY\" electron-builder --mac --universal",
    "dist:win": "npm run build && electron-builder --win nsis --x64",
    "dist:linux": "npm run build && electron-builder --linux AppImage deb rpm --x64",
    "dist:all": "node scripts/build-all-platforms.mjs",
    "lint": "eslint --ext .ts,.tsx .",
    "test": "vitest run"
  },
  "keywords": [],
  "author": {
    "name": "Qzrzz",
    "email": "qzrz256@gmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "5.62.0",
    "@typescript-eslint/parser": "5.62.0",
    "@vitejs/plugin-react": "6.0.3",
    "electron": "43.1.0",
    "electron-builder": "26.15.3",
    "eslint": "8.57.1",
    "eslint-plugin-import": "2.32.0",
    "typescript": "7.0.2",
    "vite": "5.4.21",
    "vitest": "4.1.10"
  },
  "dependencies": {
    "chalk": "5.6.2",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  }
}
